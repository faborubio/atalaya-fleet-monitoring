# Copia a terraform.tfvars y ajusta. NO subas terraform.tfvars con secretos al repo.
project_id = "fabian-portafolio"
region     = "us-central1"

# Imágenes en Artifact Registry. El Nivel 2 (demo-up.ps1) publica api:live/worker:live y las pasa
# por -var; estos valores son el fallback para aplicar a mano:
api_image    = "us-central1-docker.pkg.dev/fabian-portafolio/atalaya/api:live"
worker_image = "us-central1-docker.pkg.dev/fabian-portafolio/atalaya/worker:live"

# Token de ingesta (cámbialo). Va a Secret Manager.
ingest_token = "change-me-ingest-token"

# Orígenes del SPA "live" (Nivel 2, ADR-014 / DEMO.md): sitio Firebase atalaya-live.
cors_origins = ["https://atalaya-live.web.app", "https://atalaya-live.firebaseapp.com"]
