<?xml version="1.0" encoding="utf-8"?>
<!-- Fuentes NuGet del repo. Garantiza restore reproducible aunque la máquina no tenga
     fuentes globales configuradas (ver TROUBLESHOOTING TS-004). -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
