{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Telemetry": {
    "Transport": "Aws"
  },
  "Ingest": {
    "Token": "dev-ingest-token",
    "RatePerSecond": 500
  },
  "Auth": {
    "Mode": "Dev",
    "Issuer": "atalaya-dev",
    "Audience": "atalaya",
    "DevSigningKey": "dev-only-hs256-signing-key-change-me-1234567890abcd",
    "TokenLifetimeMinutes": 480
  },
  "Aws": {
    "ServiceUrl": "http://localhost:4566",
    "Region": "us-east-1",
    "TopicName": "atalaya-telemetry"
  },
  "Gcp": {
    "ProjectId": "atalaya-local",
    "TopicId": "atalaya-telemetry",
    "EmulatorHost": "localhost:8085"
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=atalaya;Username=atalaya;Password=atalaya",
    "Redis": "localhost:6379"
  }
}
