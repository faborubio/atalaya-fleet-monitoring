{
  "name": "atalaya-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/atalaya-web/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/atalaya-web",
        "browser": "apps/atalaya-web/src/main.ts",
        "polyfills": [],
        "tsConfig": "apps/atalaya-web/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "allowedCommonJsDependencies": ["long", "pbf", "jszip", "pako", "snappyjs"],
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/atalaya-web/public"
          }
        ],
        "styles": ["apps/atalaya-web/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        },
        "demo": {
          "budgets": [
            { "type": "initial", "maximumWarning": "500kb", "maximumError": "1mb" },
            { "type": "anyComponentStyle", "maximumWarning": "4kb", "maximumError": "8kb" }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/atalaya-web/src/app/core/deploy-target.ts",
              "with": "apps/atalaya-web/src/app/core/deploy-target.demo.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "atalaya-web:build:production"
        },
        "development": {
          "buildTarget": "atalaya-web:build:development"
        },
        "demo": {
          "buildTarget": "atalaya-web:build:demo"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "atalaya-web:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/atalaya-web/jest.config.ts",
        "tsConfig": "apps/atalaya-web/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "atalaya-web:build",
        "staticFilePath": "dist/apps/atalaya-web/browser",
        "spa": true
      }
    }
  }
}
